# Pi Smart Display — Backend Environment Variables
# Copy this file to .env and fill in your values.
# The server reads these automatically if you use: node --env-file=.env server.js

# Port the server listens on (default: 8787)
PORT=8787

# Directory where config.json and snapshot.json are stored (default: ./data)
DATA_DIR=./data

# Full path to config file — overrides DATA_DIR if set
# CONFIG_PATH=/opt/pi-smart-display/data/config.json

# Set to "true" to enable verbose request logging (default: false)
DEBUG_LOGS=false

# Admin token — if set, POST /api/config and POST /api/clear-cache require
# the x-admin-token header to match this value.
# Generate a strong random token: openssl rand -hex 32
# ADMIN_TOKEN=your-secret-token-here
